{
  "// what this is": "A ready-made writing environment. Opening this folder in VS Code with Docker running gives you Sphinx, a live preview[% if use_vale %], and the Vale style checker[% endif %] with nothing to install by hand. See CONTRIBUTING.md.",

  "name": "[[ document_title ]]",
  "image": "mcr.microsoft.com/devcontainers/python:[[ python_version ]]",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},

    // Screenshots and photographs are stored in Git LFS -- see .gitattributes.
    // This feature installs git-lfs *and* runs `git lfs install`, which is the
    // part that matters: without the filter registered, dropping a screenshot
    // into docs/ commits the whole file into history instead of a pointer, and
    // CI rejects the push. Nobody writing a manual should have to know that,
    // so the container knows it for them.
    "ghcr.io/devcontainers/features/git-lfs:1": {}
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  // The live preview. VS Code forwards it automatically and offers to open it.
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Manual preview",
      "onAutoForward": "openPreview"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "executablebookproject.myst-highlight",
        "streetsidesoftware.code-spell-checker",
        "redhat.vscode-yaml"[% if use_vale %],
        "chrischinchilla.vale-vscode"[% endif %][% if build_pdf %],
        // So the finished PDF opens in a tab when the build is done. Without
        // it VS Code treats a .pdf as a binary file and offers to download it,
        // which is a strange thing to be offered for a file you just made.
        "tomoki1207.pdf"[% endif %]
      ],
      "settings": {
        // Python lives here only to build the document; nobody writing the
        // manual should be shown Python tooling.
        "python.defaultInterpreterPath": "/workspaces/[[ project_slug ]]/.venv/bin/python"
      }
    }
  }
}
