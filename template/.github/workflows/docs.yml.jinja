name: Docs

on:
  push:
    branches: [main]
  pull_request:

jobs:
  # Screenshots and photographs belong in Git LFS -- see .gitattributes for why.
  # `filter=lfs` there is a request, not a guarantee: it does nothing unless
  # git-lfs is installed where the commit was made, and when it is missing Git
  # commits the whole file with no warning at all. By the time anyone notices,
  # the bytes are in the history of an issued document and cannot be taken out
  # without rewriting it. So catch it here, on the pull request, while removing
  # it is still one amended commit.
  assets:
    runs-on: ubuntu-latest
    steps:
      # No `lfs: true`: this job reads what the *commit* stores, and fetching
      # the real files would defeat the check.
      - uses: actions/checkout@v7

      - name: Check art assets are in LFS
        run: |
          # For every tracked file, ask Git whether .gitattributes assigns it
          # the lfs filter, then read the blob out of the index. A file that is
          # meant to be in LFS but does not begin with the pointer header was
          # committed by someone without git-lfs installed.
          # Newline-separated, not space-separated: "wiring diagram.png" is a
          # perfectly ordinary name for a writer to give a file.
          offenders=""
          while IFS= read -r file; do
            [ -n "$file" ] || continue
            # `check-attr` prints "<path>: filter: <value>"; the value is the
            # last field, which is the one part of that line a path cannot
            # disturb by containing a colon.
            [ "$(git check-attr filter -- "$file" | awk '{print $NF}')" = "lfs" ] || continue
            if ! git cat-file -p ":$file" 2>/dev/null | head -n1 | grep -q '^version https://git-lfs\.github\.com/spec/'; then
              offenders="$offenders$file"$'\n'
            fi
          done < <(git ls-files)

          if [ -n "$offenders" ]; then
            while IFS= read -r file; do
              [ -n "$file" ] || continue
              echo "::error file=$file::$file was committed to Git directly instead of to Git LFS."
            done <<< "$offenders"
            cat >&2 <<'HELP'

          ------------------------------------------------------------------
          Some art assets were committed as ordinary files.

          This usually means git-lfs was not installed on the machine that made
          the commit. The fix, from inside the dev container (which has it):

            git lfs install
            git rm --cached <the files listed above>
            git add <the files listed above>
            git commit --amend --no-edit
            git push --force-with-lease

          If you are not sure, say so on the pull request rather than force
          pushing -- someone will sort it out with you.
          ------------------------------------------------------------------

          HELP
            exit 1
          fi
          echo "All art assets are stored in LFS."

  build:
    runs-on: ubuntu-latest
    steps:
      # Images are LFS pointers in the commit; without this the build embeds
      # the pointer files and publishes a manual full of broken figures.
      - uses: actions/checkout@v7
        with:
          lfs: true

      - uses: astral-sh/setup-uv@v8.3.2
        with:
          python-version: "[[ python_version ]]"

      - run: uv sync --group docs

      # Every file this workflow publishes is named for the document number and
      # revision, so a copy that has been emailed around still says what it is.
      # The name comes from revisions.yaml via spiri_docs -- the same call that
      # names the PDF -- rather than being spelled out again in YAML, where it
      # would drift and publish SPIRI-OM-001_rev1.1.pdf with a rev1.2 footer.
      - name: Read the document name
        id: doc
        run: uv run python -m spiri_docs fields >> "$GITHUB_OUTPUT"

      # Also validates revisions.yaml -- a regulator-facing revision with no
      # approver or effective date fails here rather than reaching a reader.
      - name: Build HTML
        run: uv run sphinx-build -b html -W docs docs/_build/html

      # Zipped explicitly rather than handing the directory to upload-artifact.
      # Two reasons: the release attaches this exact file, and a bare directory
      # is not a file an act runner can hand back -- act writes artifact
      # contents to disk as-is and does no zipping of its own.
      - name: Package HTML
        run: |
          mkdir -p dist
          uv run python -c "
          import shutil
          shutil.make_archive('dist/${{ steps.doc.outputs.name }}_html', 'zip', 'docs/_build/html')
          "

      - name: Upload HTML
        uses: actions/upload-artifact@v7
        with:
          name: ${{ steps.doc.outputs.name }}_html
          path: dist/${{ steps.doc.outputs.name }}_html.zip
          if-no-files-found: error
[% if build_pdf %]
  # The PDF is built on every run, not just on tags, so what reviewers look at
  # is the artifact the release will carry. The cost is the LaTeX install below
  # (a few minutes, and it dominates this job); if that becomes the slowest part
  # of a pull request, narrow the trigger to `if: github.ref == 'refs/heads/main'`
  # rather than dropping the job -- a PDF that only ever builds on a tag is a
  # PDF whose first failure is on the day you are trying to issue a revision.
  pdf:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v7
        with:
          lfs: true

      - uses: astral-sh/setup-uv@v8.3.2
        with:
          python-version: "[[ python_version ]]"

      - run: uv sync --group docs

      - name: Read the document name
        id: doc
        run: uv run python -m spiri_docs fields >> "$GITHUB_OUTPUT"

      # texlive-latex-extra carries the packages Sphinx's LaTeX output expects
      # (framed, titlesec, wrapfig, capt-of); latexmk drives the build.
      - name: Install LaTeX
        run: |
          sudo apt-get update
          sudo apt-get install -y --no-install-recommends \
            latexmk texlive-latex-recommended texlive-latex-extra \
            texlive-fonts-recommended tex-gyre[% if use_spiri_brand %] \
            librsvg2-bin[% endif %]
[%- if use_spiri_brand %]
          # librsvg2-bin converts the cover logo from SVG, which pdflatex cannot
          # read. The build below runs with -W, so a missing converter fails the
          # build rather than quietly issuing an unbranded controlled document.
[%- endif %]

      # spiri_docs names the .tex (and so the .pdf) after the document number and
      # revision, which is why nothing is renamed afterwards.
      - name: Build PDF
        run: |
          uv run sphinx-build -b latex -W docs docs/_build/latex
          make -C docs/_build/latex all-pdf
          mkdir -p dist
          cp docs/_build/latex/${{ steps.doc.outputs.name }}.pdf dist/

      - name: Upload PDF
        uses: actions/upload-artifact@v7
        with:
          name: ${{ steps.doc.outputs.name }}_pdf
          path: dist/${{ steps.doc.outputs.name }}.pdf
          if-no-files-found: error
[% endif %][% if use_vale %]
  prose:
    runs-on: ubuntu-latest
    # Advisory for now: this reports style-guide findings without blocking a
    # merge. Flip to `false` once the house style guide is settled and the team
    # has had a chance to get used to it.
    continue-on-error: true
    steps:
      - uses: actions/checkout@v7
      - uses: errata-ai/vale-action@v2.1.2
        with:
          files: docs
          fail_on_error: false
          reporter: github-pr-check
[% endif %]
