# Read the Docs builds the browsable copy of this manual.
#
# Note the split, which is deliberate: RTD rebuilds a version in place, so the
# PDF at a given RTD URL can change after it is issued. That is fine for reading
# and wrong for a controlled document. The controlled PDF is the one CI attaches
# to a GitHub release -- see .github/workflows/release.yml.

version: 2

build:
  os: ubuntu-24.04
  tools:
    python: "[[ python_version ]]"
[%- if build_pdf %]
  # RTD does not grant sudo to build jobs, so anything the PDF needs beyond the
  # image's own TeX toolchain has to come through `apt_packages`.
  apt_packages:
[%- if use_spiri_brand %]
    # The cover logo is SVG, which pdflatex cannot read, so the build converts
    # it -- see .devcontainer/setup.sh, which installs the same package.
    - librsvg2-bin
[%- endif %]
    # TikZ, which draws the ANSI Z535 safety alert symbol on the hazard panels.
    # Listed rather than assumed: `fail_on_warning` above covers Sphinx warnings
    # only, so if this were missing the LaTeX warning would scroll past and RTD
    # would publish a manual whose DANGER panels carry no symbol, with nothing
    # failing. spiri-docs makes that a hard error for the same reason.
    - texlive-pictures
[%- endif %]
  jobs:
    # Fetch the art assets. Screenshots and photographs live in Git LFS (see
    # .gitattributes), and RTD's image has no git-lfs and grants no sudo to
    # install one, so the binary is fetched here and pointed at by absolute
    # path. Without this the checkout leaves 130-byte pointer files where the
    # images should be and the build *succeeds*, publishing a manual whose
    # figures are all broken -- which is why this is not best-effort.
    #
    # Adapted from the recipe in RTD's build-customization guide; the tarball
    # layout there is stale, as the binary has been under a versioned directory
    # since 3.x, hence --strip-components.
    post_checkout:
      - wget -q https://github.com/git-lfs/git-lfs/releases/download/v3.7.1/git-lfs-linux-amd64-v3.7.1.tar.gz
      - tar xzf git-lfs-linux-amd64-v3.7.1.tar.gz --strip-components=1 git-lfs-3.7.1/git-lfs
      - git config filter.lfs.process "$(pwd)/git-lfs filter-process"
      - git config filter.lfs.smudge "$(pwd)/git-lfs smudge -- %f"
      - git config filter.lfs.clean "$(pwd)/git-lfs clean -- %f"
      - ./git-lfs install --local
      - ./git-lfs fetch
      - ./git-lfs checkout

    install:
      - pip install uv
      - uv sync --group docs
    build:
      html:
        - uv run sphinx-build -b html docs $READTHEDOCS_OUTPUT/html
[%- if build_pdf %]
      # Taking over `build.jobs.build` does not replace `formats:` -- it makes
      # it required. RTD checks the two agree and rejects the config if a build
      # type appears here without being listed there, so the `formats:` block
      # below has to be kept in step with this one.
      #
      # latexmk and the TeX toolchain are present in the ubuntu-24.04 image --
      # confirmed on a real build, which got as far as running latexmk 4.83.
      pdf:
        - uv run sphinx-build -b latex docs docs/_build/latex
        - make -C docs/_build/latex all-pdf
        - mkdir -p $READTHEDOCS_OUTPUT/pdf
        # Exactly one file, named for the project slug. RTD enforces both, and
        # is unhelpful about the second: a wrongly named PDF has failed with
        # "Unknown problem ... report this to us with your build id" rather than
        # anything actionable. See readthedocs.org#10873, which notes the naming
        # rule "is not documented anywhere".
        #
        # The source name is still `spiri_docs name`[% if use_spiri_brand %], which also picks the
        # document out from beside the cover logo Sphinx copies into the build
        # directory[% endif %].
        #
        # Renaming on the way out costs nothing: this PDF is the uncontrolled
        # reading copy, and RTD renames it for hosting regardless. The
        # controlled PDF keeps the document number -- see release.yml.
        - cp "docs/_build/latex/$(uv run python -m spiri_docs name).pdf" "$READTHEDOCS_OUTPUT/pdf/$READTHEDOCS_PROJECT.pdf"
[%- endif %]
[%- if build_pdf %]

# Declares which formats this project publishes. Required because the build
# jobs above name `pdf` explicitly; see the note there.
formats:
  - pdf
[%- endif %]

sphinx:
  configuration: docs/conf.py
  # A manual with a broken cross-reference is a manual that sends someone to the
  # wrong procedure. Fail rather than warn.
  fail_on_warning: true
